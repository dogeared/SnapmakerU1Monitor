# Host port mapped to the container's 8080
PORT=8080

# --- Security (OIDC) ---
# Set to false to run without authentication
GLOBAL_SECURITY_ENABLED=true

# Required when GLOBAL_SECURITY_ENABLED=true
OIDC_CLIENT_ID=your-client-id
OIDC_ISSUER_URI=https://your-provider.example.com

# --- Printer ---
PRINTER_HOST=192.168.68.105
PRINTER_PORT=7125
